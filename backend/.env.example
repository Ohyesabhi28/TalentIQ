# ─────────────────────────────────────────────────────────────────
# TalentIQ Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────────────────────
APP_NAME="TalentIQ API"
APP_VERSION="0.1.0"
APP_ENV="development"          # development | staging | production
DEBUG=false

# ── Server ─────────────────────────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000

# ── Security ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="change-me-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Example for production: CORS_ORIGINS=["https://app.talentiq.io"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://talentiq:talentiq@localhost:5432/talentiq"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ── Object Storage (AWS S3) ────────────────────────────────────────────────
S3_BUCKET_NAME="talentiq-files"
S3_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
S3_PRESIGNED_URL_EXPIRY_SECONDS=3600

# ── File Upload ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_BYTES=5242880     # 5 MB

# ── AI / LLM ───────────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.0-flash"
EMBEDDING_MODEL="models/text-embedding-004"

# ── Support ────────────────────────────────────────────────────────────────
SUPPORT_EMAIL="support@talentiq.io"

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"                # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_JSON=false                  # Set true in production for structured JSON logs
